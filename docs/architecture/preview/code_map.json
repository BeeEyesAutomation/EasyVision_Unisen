  "established_conventions_phase_0_to_2": {
    "tool_resolution": "Common.TryGetTool / TryGetToolList / EnsureToolList / EnsureCurrentToolList / SetToolList",
    "forbidden": "Common.PropetyTools[ip][it] — direct two-level indexing (CI guard: tools/check_propety_tools.sh)",
    "event_subscribe": "ALWAYS pair: X.Event -= Handler; X.Event += Handler;",
    "owner_tool_cache": "Each ToolXxx caches private PropetyTool _ownerTool; getter calls Common.TryGetTool(Global.IndexProgChoose, Propety.Index); InvalidateOwnerToolCache() to refresh",
    "namespace_freeze": "BeeCore (root namespace) MUST NOT change for [Serializable] payload classes in Unit/* — file is loaded with type lookup by full name",
    "events_on_state": "ToolState exposes ScoreChanged, PercentChange, StatusToolChanged, ToolDoneChanged"
  },

  "duplicates_to_unify": {
    "CustomGui.cs": ["BeeCore/CustomGui.cs", "BeeCore/Func/CustomGui.cs", "BeeInterface/CustomGui.cs"],
    "Converts.cs":  ["BeeCore/Converts.cs", "BeeCore/Func/Converts.cs"],
    "ShapeEditing/*": ["BeeCore/ShapeEditing/*", "BeeInterface/ShapeEditing/*"],
    "Global state": ["BeeGlobal/Global.cs", "BeeInterface/Global.cs", "BeeCore/Parameter/G.cs", "BeeUi/Global.cs"]
  },

  "designer_pattern_in_tools": {
    "_typical_layout": "TabControl tabControl2 → 2-4 TabPage → TableLayoutPanel → mix of: RJButton (action btn), AdjustBarEx (slider trackScore/trackThreshold/trackMinInlier/AdjScale), Cyotek.ImageBox (preview), Label, GradientTab, ItemTool",
    "_visible_in_ToolCircle": "tabControl2, tabP1, tabPage4, btnCalib, btn1..btn5, btnNewShape/Polygon/Hexagon/Elip/Rect, btnArea/Crop/Mask, btnBlack/White, btnCropFull/CropHalt, btnInsideOut/OutsideIn, btnInvert/Binary/StrongEdge/CloseEdge, AdjScale, AdjThreshod, trackScore, trackThreshold, trackMinInlier, multiple TableLayoutPanels"
  },

  "save_load_pipeline": {
    "save_program": "SaveData.Program(string Project, List<List<PropetyTool>> Prog) → Access.SaveProg(path, list) → SerializeToBase64(BinaryFormatter) → AtomicWriteAllText(.tmp+Replace+.bak)",
    "load_program": "LoadData.Project(string Project) → Access.LoadProg(path) → File.ReadAllText(UTF8) → Convert.FromBase64String → BinaryFormatter.Deserialize → List<List<PropetyTool>>",
    "path_selector": "if Global.Config.IsSaveProg: Common\\Common.prog ; else: Program\\<Project>\\<Project>.prog",
    "ancillary_files": {
      ".para":   "ParaCommon",
      ".cam":    "List<ParaCamera>",
      ".com":    "Comunication",
      ".gc":     "ParaShow",
      ".img":    "List<ItemRegsImg> register",
      ".sim":    "List<ItemRegsImg> simulation",
      ".config": "Config",
      ".no":     "List<ProgNo>",
      ".prog":   "List<List<PropetyTool>>"
    }
  }
